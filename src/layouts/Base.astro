---
import { NAV, GAME_URL, withBase } from '../config/site.js';
import '../styles/global.css';

const { title, description = '새우 키우기 시뮬레이션 게임 Shrimprium 공식 사이트' } = Astro.props;
const pageTitle = title ? `${title} — Shrimprium` : 'Shrimprium — 새우 키우기 시뮬레이션';
const currentPath = Astro.url.pathname;
const isCurrent = (href) => currentPath.startsWith(withBase(href));
---
<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#0b0f14" />
  <title>{pageTitle}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={new URL(currentPath, Astro.site)} />
  <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
</head>
<body>
  <!-- 배경 픽셀 기포 -->
  <div class="bubble-layer" aria-hidden="true">
    <i class="px-bubble"></i><i class="px-bubble"></i><i class="px-bubble"></i><i class="px-bubble"></i><i class="px-bubble"></i>
  </div>

  <header class="site-header">
    <div class="inner">
      <a class="site-logo" href={withBase('/')}>
        <span class="logo-ico">🦐</span>SHRIMPRIUM
      </a>
      <a class="play-btn" href={GAME_URL}>▶ 플레이하기</a>
    </div>
    <nav class="site-nav" aria-label="주요 메뉴">
      <div class="inner">
        {NAV.map((item) => (
          <a class="site-nav-link" href={withBase(item.href)} aria-current={isCurrent(item.href) ? 'page' : undefined}>{item.label}</a>
        ))}
      </div>
    </nav>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <nav>
      <a href={withBase('/privacy.html')}>개인정보처리방침</a>
      <a href={withBase('/support/')}>문의/지원</a>
    </nav>
    <p>© {new Date().getFullYear()} Shrimprium</p>
    <p class="font-credit">Galmuri font © Minseo Lee · SIL OFL 1.1</p>
  </footer>
</body>
</html>
