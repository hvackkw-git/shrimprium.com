---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { withBase } from '../../config/site.js';

export async function getStaticPaths() {
  const docs = await getCollection('guide');
  return docs.map((doc) => ({ params: { id: doc.id }, props: { doc } }));
}

const { doc } = Astro.props;
const { Content } = await render(doc);
---
<Base title={doc.data.title} description={doc.data.description}>
  <h1>{doc.data.title}</h1>
  <div class="prose">
    <Content />
  </div>
  <p style="margin-top: 40px;"><a href={withBase('/guide/')}>← 새우백과로</a></p>
</Base>
