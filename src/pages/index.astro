---
import Base from '../layouts/Base.astro';
import { withBase } from '../config/site.js';
---
<Base>
  <!-- 장식용 수조: 수초 3개 + 새우 2마리가 무작위로 헤엄치고 뛴다. 게임 기능은 없음. -->
  <section
    class="tank"
    aria-label="새우가 헤엄치는 장식용 수조"
    data-red={withBase('/assets/shrimp-swim-red.png')}
    data-blue={withBase('/assets/shrimp-swim-blue.png')}
  >
    <div class="tank-water">
      <i class="tank-surface" aria-hidden="true"></i>

      <!-- 수초 3개 -->
      <div class="tank-plant" style="left: 16%;" aria-hidden="true">
        <i class="blade b1"></i><i class="blade b2"></i><i class="blade b3"></i>
      </div>
      <div class="tank-plant tall" style="left: 50%;" aria-hidden="true">
        <i class="blade b1"></i><i class="blade b2"></i><i class="blade b3"></i><i class="blade b4"></i>
      </div>
      <div class="tank-plant short" style="left: 82%;" aria-hidden="true">
        <i class="blade b1"></i><i class="blade b2"></i><i class="blade b3"></i>
      </div>

      <!-- 새우 2마리 (위치는 스크립트가 제어) -->
      <div class="tank-shrimp" data-color="red" aria-hidden="true"><i class="sprite"></i></div>
      <div class="tank-shrimp" data-color="blue" aria-hidden="true"><i class="sprite"></i></div>
    </div>
    <div class="tank-substrate" aria-hidden="true"></div>
  </section>

  <script>
    const tank = document.querySelector('.tank');
    const water = tank.querySelector('.tank-water');
    const shrimps = [...tank.querySelectorAll('.tank-shrimp')];

    // 스프라이트 시트 경로를 data-속성에서 주입 (base 경로 대응)
    shrimps.forEach((s) => {
      const url = tank.dataset[s.dataset.color === 'red' ? 'red' : 'blue'];
      s.querySelector('.sprite').style.backgroundImage = `url(${url})`;
    });

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const SIZE = 32;          // 스프라이트 한 프레임 크기
    const rand = (a, b) => a + Math.random() * (b - a);

    function bounds() {
      return { w: water.clientWidth - SIZE, h: water.clientHeight - SIZE };
    }

    const fish = shrimps.map((el, i) => {
      const b = bounds();
      return {
        el,
        sprite: el.querySelector('.sprite'),
        x: rand(b.w * 0.2, b.w * 0.8),
        y: rand(b.h * 0.25, b.h * 0.7),
        vx: rand(-0.4, 0.4) || 0.3,
        vy: rand(-0.2, 0.2),
        turnAt: 0,
        jumpAt: rand(1500, 4000) * (i + 1),
        face: 1,
      };
    });

    function draw(f) {
      f.el.style.transform = `translate(${f.x}px, ${f.y}px)`;
      // 스프라이트는 왼쪽을 바라봄 → 오른쪽으로 갈 때 좌우 반전
      f.sprite.style.transform = `scale(${1.7 * f.face}, 1.7)`;
    }

    if (reduce) {
      // 모션 최소화: 가만히 배치만 한다
      fish.forEach(draw);
    } else {
      let last = performance.now();
      function tick(now) {
        const dt = Math.min(now - last, 50);
        last = now;
        const b = bounds();
        for (const f of fish) {
          // 가끔 방향/속도를 부드럽게 바꿈 (무작위 유영)
          if (now > f.turnAt) {
            f.vx += rand(-0.25, 0.25);
            f.vy += rand(-0.15, 0.15);
            f.turnAt = now + rand(700, 2200);
          }
          // 가끔 폭발적으로 튀어오름 (뛰기)
          if (now > f.jumpAt) {
            f.vx += rand(-1.6, 1.6);
            f.vy -= rand(1.4, 2.6);
            f.jumpAt = now + rand(2500, 6000);
          }
          // 약한 부력 + 속도 감쇠로 자연스럽게
          f.vy += 0.012;
          f.vx *= 0.985;
          f.vy *= 0.99;
          // 최대 속도 제한
          f.vx = Math.max(-2.4, Math.min(2.4, f.vx));
          f.vy = Math.max(-3, Math.min(2.4, f.vy));

          f.x += f.vx * dt * 0.06;
          f.y += f.vy * dt * 0.06;

          // 벽에서 튕김
          if (f.x < 0) { f.x = 0; f.vx = Math.abs(f.vx); }
          if (f.x > b.w) { f.x = b.w; f.vx = -Math.abs(f.vx); }
          if (f.y < 0) { f.y = 0; f.vy = Math.abs(f.vy) * 0.6; }
          if (f.y > b.h) { f.y = b.h; f.vy = -Math.abs(f.vy); }

          if (Math.abs(f.vx) > 0.05) f.face = f.vx > 0 ? -1 : 1;
          draw(f);
        }
        requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    }
  </script>
</Base>
