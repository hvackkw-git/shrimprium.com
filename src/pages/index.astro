---
import Base from '../layouts/Base.astro';
---
<Base>
  <!-- 게임 화면 그대로의 수조: 코스믹 배경 · 윤슬 · 마린스노우 · 자갈 · 수초 · 새우 2마리.
       게임 기능은 없는 순수 연출(초기 화면). -->
  <section class="gametank" aria-label="새우가 헤엄치는 수조">
    <div class="gametank-scene" id="gametankScene">
      <div class="gt-bg" aria-hidden="true"></div>
      <div class="gt-bg-overlay" aria-hidden="true"></div>
      <div class="gt-ripple" aria-hidden="true"></div>
      <div class="gt-snow-back" aria-hidden="true"></div>
      <div class="gt-gravel" id="gtGravel" aria-hidden="true"></div>
      <div class="gt-caustics" aria-hidden="true"></div>
      <div class="gt-depth-haze" aria-hidden="true"></div>
      <div class="gt-plants" aria-hidden="true">
        <img src="/assets/seaweed/seaweed_s03.png" alt="" draggable="false" />
        <img src="/assets/seaweed/seaweed_s08.png" alt="" draggable="false" />
        <img src="/assets/seaweed/seaweed_s11.png" alt="" draggable="false" />
      </div>
      <div class="gt-shrimp-layer" id="gtShrimp" aria-hidden="true">
        <div class="gt-shrimp" data-color="red"><i class="sprite"></i></div>
        <div class="gt-shrimp" data-color="blue"><i class="sprite"></i></div>
      </div>
      <div class="gt-snow-front" aria-hidden="true"></div>
      <div class="gt-vignette" aria-hidden="true"></div>
    </div>
  </section>

  <script>
    const SCENE_W = 320, SCENE_H = 640;
    const frame = document.querySelector('.gametank');
    const scene = document.getElementById('gametankScene');

    // 320 폭 월드를 프레임 너비에 맞춰 스케일 (게임 로그인 화면과 동일한 방식)
    const fit = () => { scene.style.setProperty('--gt-scale', (frame.clientWidth / SCENE_W).toString()); };
    fit();
    new ResizeObserver(fit).observe(frame);

    // ── 자갈: 게임 본체(mountAquarium)의 캔버스 베이크를 그대로 이식 ──
    (function buildGravel() {
      const layer = document.getElementById('gtGravel');
      const underlay = document.createElement('div');
      underlay.className = 'gravel-underlay';
      layer.appendChild(underlay);

      const makeRng = (seed) => { let s = seed >>> 0; return () => { s = (Math.imul(s, 1664525) + 1013904223) | 0; return (s >>> 0) / 0x100000000; }; };
      const W = 320, H = 50;
      const cv = document.createElement('canvas');
      cv.className = 'gravel-sprite';
      cv.width = W; cv.height = H;
      const c = cv.getContext('2d');
      const rng = makeRng(0x6B5A47); // 시드 고정 — 항상 같은 자갈밭
      const shades = [
        ['#384d65', '#1f2b38', '#17202a', '#10161c'],
        ['#415c77', '#243342', '#1b2632', '#121a21'],
        ['#202f3b', '#121a21', '#0e1419', '#090d11'],
        ['#58687c', '#313a45', '#252c34', '#191d23'],
      ];
      const pebble = (cx, cy, rx, ry, alpha) => {
        const [hi, base, mid, sh] = shades[Math.floor(rng() * shades.length)];
        c.globalAlpha = alpha;
        const X = Math.round(cx), Y = Math.round(cy);
        for (let dy = -ry; dy <= ry; dy++) {
          const t = dy / (ry + 0.5);
          const hw = Math.round(rx * Math.sqrt(1 - t * t));
          const y = Y + dy;
          const ringHw = (s, o) => { const tt = (dy + ry * o) / (ry * s + 0.5); return tt >= -1 && tt <= 1 ? Math.min(hw, Math.round(rx * s * Math.sqrt(1 - tt * tt))) : -1; };
          let w1 = ringHw(0.88, 0.22); const w2 = ringHw(0.7, 0.4);
          if (w1 < w2) w1 = w2;
          if (w2 >= 0) { c.fillStyle = base; c.fillRect(X - w2, y, w2 * 2 + 1, 1); }
          if (w1 >= 0) {
            if (w1 > w2) {
              c.fillStyle = mid;
              if (w2 >= 0) { c.fillRect(X - w1, y, w1 - w2, 1); c.fillRect(X + w2 + 1, y, w1 - w2, 1); }
              else { c.fillRect(X - w1, y, w1 * 2 + 1, 1); }
            }
            if (hw > w1) { c.fillStyle = sh; c.fillRect(X - hw, y, hw - w1, 1); c.fillRect(X + w1 + 1, y, hw - w1, 1); }
          } else { c.fillStyle = sh; c.fillRect(X - hw, y, hw * 2 + 1, 1); }
          const th = (dy + ry * 0.45) / (ry * 0.38 + 0.5);
          if (th >= -1 && th <= 1) {
            const hhw = Math.round(rx * 0.42 * Math.sqrt(1 - th * th));
            const hx = X - Math.round(rx * 0.15);
            const x0 = Math.max(X - hw, hx - hhw), x1 = Math.min(X + hw, hx + hhw);
            c.fillStyle = hi; c.fillRect(x0, y, x1 - x0 + 1, 1);
          }
        }
      };
      for (let i = 0; i < 280; i++) {
        const size = 5 + rng() * 11;
        const rx = Math.max(2, Math.round(size / 2));
        const ry = Math.max(2, Math.round((size * 0.85) / 2));
        const h = ry * 2 + 1;
        const bottom = rng() * Math.max(0, H - h);
        pebble(rng() * W, H - bottom - ry - 0.5, rx, ry, 0.55 + rng() * 0.4);
      }
      c.globalAlpha = 1;
      layer.appendChild(cv);
    })();

    // ── 새우 2마리: 무작위로 헤엄치고 가끔 튀어오른다 ──
    const shrimps = [...document.querySelectorAll('.gt-shrimp')];
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const SIZE = 32;
    const rand = (a, b) => a + Math.random() * (b - a);
    const X_MAX = SCENE_W - SIZE;            // 0..288
    const Y_MIN = 36, Y_MAX = SCENE_H - 56 - SIZE; // 수면 아래 ~ 자갈 위

    const fish = shrimps.map((el, i) => ({
      el,
      sprite: el.querySelector('.sprite'),
      x: rand(X_MAX * 0.2, X_MAX * 0.8),
      y: rand(Y_MIN + 40, Y_MAX - 40),
      vx: rand(-0.4, 0.4) || 0.3,
      vy: rand(-0.2, 0.2),
      turnAt: 0,
      jumpAt: rand(1500, 4000) * (i + 1),
      face: 1,
    }));

    const draw = (f) => {
      f.el.style.transform = `translate(${f.x}px, ${f.y}px)`;
      f.sprite.style.transform = `scale(${1.3 * f.face}, 1.3)`; // 왼쪽 바라봄 → 오른쪽 갈 때 반전
    };

    if (reduce) {
      fish.forEach(draw);
    } else {
      let last = performance.now();
      const tick = (now) => {
        const dt = Math.min(now - last, 50); last = now;
        for (const f of fish) {
          if (now > f.turnAt) { f.vx += rand(-0.25, 0.25); f.vy += rand(-0.15, 0.15); f.turnAt = now + rand(700, 2200); }
          if (now > f.jumpAt) { f.vx += rand(-1.6, 1.6); f.vy -= rand(1.4, 2.6); f.jumpAt = now + rand(2500, 6000); }
          f.vy += 0.012; f.vx *= 0.985; f.vy *= 0.99;
          f.vx = Math.max(-2.4, Math.min(2.4, f.vx));
          f.vy = Math.max(-3, Math.min(2.4, f.vy));
          f.x += f.vx * dt * 0.06; f.y += f.vy * dt * 0.06;
          if (f.x < 0) { f.x = 0; f.vx = Math.abs(f.vx); }
          if (f.x > X_MAX) { f.x = X_MAX; f.vx = -Math.abs(f.vx); }
          if (f.y < Y_MIN) { f.y = Y_MIN; f.vy = Math.abs(f.vy) * 0.6; }
          if (f.y > Y_MAX) { f.y = Y_MAX; f.vy = -Math.abs(f.vy); }
          if (Math.abs(f.vx) > 0.05) f.face = f.vx > 0 ? -1 : 1;
          draw(f);
        }
        requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    }
  </script>
</Base>
