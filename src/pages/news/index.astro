---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { withBase } from '../../config/site.js';

const posts = (await getCollection('news')).sort((a, b) => b.data.date - a.data.date);
const fmt = (d) => d.toISOString().slice(0, 10);
---
<Base title="소식" description="Shrimprium 업데이트 소식과 공지사항">
  <h1>소식</h1>
  <ul class="card-list">
    {posts.map((post) => (
      <li>
        <a class="card" href={withBase(`/news/${post.id}/`)}>
          <p class="card-meta">{fmt(post.data.date)}</p>
          <p class="card-title">{post.data.title}</p>
          {post.data.description && <p class="card-desc">{post.data.description}</p>}
        </a>
      </li>
    ))}
  </ul>
</Base>
